package java_record;
import java.util.Scanner; 
public class p2 { 
	public static void main(String[] args) { 
		Scanner scanner=new Scanner(System.in); 
		System.out.print("Enter no.of rows:"); 
		int n=scanner.nextInt(); 
		for(int i=1;i<=n;i++) {
			for(int j=i;j<=n-1;j++) {
				System.out.print(" "+" "); 
				} 
			for(int k=1;k<=i;k++) {
				System.out.print("* "); 
				} 
			System.out.println();
			} 
		scanner.close(); 
		} 
	} 
