package java_record;
public class p5 {
	public static void main(String[] args) {
		int rows =7;
		for(int i=0;i<rows;i++) {
			for(int j =0;j<i;j++) {
				System.out.print(" "+" ");
			}
			for(char ch='A';ch < 'A' + (rows - i);ch++) {
				System.out.print(ch+" ");
			}
			System.out.println();
		}
	}
}
